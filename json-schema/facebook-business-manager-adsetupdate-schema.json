{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/AdSetUpdate",
  "title": "AdSetUpdate",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "ACTIVE",
        "PAUSED",
        "DELETED",
        "ARCHIVED"
      ]
    },
    "daily_budget": {
      "type": "string"
    },
    "lifetime_budget": {
      "type": "string"
    },
    "targeting": {
      "type": "object"
    },
    "bid_amount": {
      "type": "integer"
    },
    "end_time": {
      "type": "string",
      "format": "date-time"
    }
  }
}